# Copy to .env and adjust as needed. .env is gitignored.

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-only-for-local-dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (matches docker-compose.yml defaults)
POSTGRES_DB=coso_cpe
POSTGRES_USER=coso_cpe
POSTGRES_PASSWORD=coso_cpe_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS — the Vite dev server origin
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Where /api/auth/microsoft/callback/ bounces the browser after SSO. Defaults
# to the Vite dev server root; override for prod.
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Microsoft Entra ID (Azure AD) SSO — optional
# ---------------------------------------------------------------------------
# Leave all three blank (the default) to disable SSO — the login screen will
# only show the username/password form.
#
# To enable, see backend/README.md → "Microsoft SSO setup" for the full
# Azure-portal walkthrough. Short version:
#   1. Register an app at https://portal.azure.com → "App registrations"
#   2. Add redirect URI http://localhost:8000/api/auth/microsoft/callback/
#   3. Copy the Application (client) ID, Directory (tenant) ID, and a new
#      client-secret *value* into the three variables below.
MICROSOFT_AUTH_CLIENT_ID=
MICROSOFT_AUTH_CLIENT_SECRET=
# Use "common" to allow both work & personal accounts, "organizations" for any
# work/school tenant, or a specific GUID to lock to one tenant (recommended).
MICROSOFT_AUTH_TENANT_ID=
# Must exactly match the URI registered in the Azure portal.
MICROSOFT_AUTH_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback/
